# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── JWT ─────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ── Clés Supabase ────────────────────────────────────────────────────────────
# Générer sur : https://supabase.com/docs/guides/self-hosting#api-keys
# ou via : npx @supabase/cli keys generate --jwt-secret <JWT_SECRET>
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Frontend (pointe vers le gateway nginx en dev) ────────────────────────────
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=${ANON_KEY}

# ── Upstash Redis (optionnel – streaks/leaderboard) ───────────────────────────
UPSTASH_REDIS_URL=https://...
UPSTASH_REDIS_TOKEN=...
